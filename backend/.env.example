NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full
SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_COOKIE_NAME=pos_mans_session
TRUST_PROXY=false
MAX_UPLOAD_BYTES=5242880
SESSION_IDLE_TIMEOUT_MINUTES=60
SESSION_ABSOLUTE_TIMEOUT_HOURS=12
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
PLATFORM_ADMIN_SEED_USERNAME=superadmin
PLATFORM_ADMIN_SEED_PASSWORD=replace-with-strong-admin-password
PLATFORM_ADMIN_SEED_PIN=replace-with-6-digit-pin
STORE_OWNER_STORE_SLUG=demo-store
STORE_OWNER_STORE_NAME=Demo Store
STORE_OWNER_USERNAME=demoowner
STORE_OWNER_PASSWORD=replace-with-strong-owner-password
STORE_OWNER_PIN=replace-with-6-digit-pin
STORE_OWNER_DISPLAY_NAME=Store Owner
