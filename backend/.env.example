NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full
SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_COOKIE_NAME=pos_mans_session
TRUST_PROXY=false
MAX_UPLOAD_BYTES=5242880
SESSION_IDLE_TIMEOUT_MINUTES=60
SESSION_ABSOLUTE_TIMEOUT_HOURS=12
MAX_SALE_DISCOUNT_BPS=10000
MAX_SALE_TAX_BPS=10000
SALE_RATE_LIMIT_WINDOW_MS=60000
SALE_RATE_LIMIT_MAX=60
UPLOAD_RATE_LIMIT_WINDOW_MS=900000
UPLOAD_RATE_LIMIT_MAX=30
AUDIT_LOG_RETENTION_DAYS=365
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
DB_QUERY_TIMEOUT_MS=10000
DB_STATEMENT_TIMEOUT_MS=10000
DB_IDLE_IN_TRANSACTION_SESSION_TIMEOUT_MS=15000
HTTPS_CERTIFICATE_CONFIRMED=false
R2_BUCKET_POLICY_CONFIRMED=false
DATABASE_BACKUP_CONFIRMED=false
MONITORING_ALERTS_CONFIRMED=false
SECRET_MANAGER_CONFIRMED=false
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
