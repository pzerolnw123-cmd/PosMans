generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlatformRole {
  NONE
  SUPER_ADMIN
}

enum StoreRole {
  OWNER
}

enum OwnerTheme {
  violet
  light
  dark
  mono
}

enum AuditAction {
  CSRF_ISSUED
  LOGIN_SUCCEEDED
  LOGIN_FAILED
  PASSWORD_CHANGED
  LOGOUT
  LOGOUT_ALL
  UPLOAD_POLICY_ISSUED
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
  STORE_PROFILE_UPDATED
  STORE_LOGO_UPDATED
  STORE_PAYMENT_SETTINGS_UPDATED
  SALE_CREATED
  SALE_CANCELLED
}

enum InventoryMovementType {
  RECEIVE
  SALE
  RETURN
  ADJUSTMENT
  DAMAGE
  CANCEL_SALE
}

enum SaleStatus {
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  QR
  CARD
  TRANSFER
  OTHER
}

enum StorePromptPayRecipientType {
  MOBILE
  NATIONAL_ID
  TAX_ID
  STATIC_QR
  BANK_ACCOUNT
}

model Store {
  id              String    @id @default(cuid())
  slug            String    @unique
  name            String
  logoUrl         String?
  logoUploadedKey String?
  promptPayEnabled Boolean @default(false)
  promptPayRecipientType StorePromptPayRecipientType @default(MOBILE)
  promptPayId     String?
  promptPayMobileId String?
  promptPayNationalId String?
  promptPayTaxId String?
  bankName        String?
  bankAccountName String?
  bankAccountNumber String?
  paymentQrImageUrl String?
  paymentQrUploadedKey String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  users           User[]
  products        Product[]
  saleOrders      SaleOrder[]
  inventoryMovements InventoryMovement[]
}

model Product {
  id                String   @id @default(cuid())
  code              String
  name              String
  category          String
  price             Int
  status            String
  trackStock        Boolean  @default(false)
  stockQuantity     Int      @default(0)
  lowStockThreshold Int      @default(0)
  imageUrl          String?
  uploadedKey       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  storeId           String
  store             Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  saleItems         SaleOrderItem[]
  inventoryMovements InventoryMovement[]

  @@unique([storeId, code])
  @@index([storeId, updatedAt])
  @@index([storeId, category, updatedAt, createdAt])
  @@index([storeId, trackStock, stockQuantity])
}

model User {
  id              String           @id @default(cuid())
  username        String           @unique
  displayName     String
  passwordHash    String
  pinHash         String?
  platformRole    PlatformRole     @default(NONE)
  storeRole       StoreRole?
  ownerTheme      OwnerTheme       @default(light)
  storeId         String?
  isActive        Boolean          @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  store           Store?           @relation(fields: [storeId], references: [id], onDelete: SetNull)
  sessions        Session[]
  auditLogs       AuditLog[]
  loginChallenges LoginChallenge[]
  saleOrders      SaleOrder[]
  inventoryMovements InventoryMovement[]

  @@index([platformRole])
  @@index([storeId, storeRole])
}

model SaleOrder {
  id              String          @id @default(cuid())
  code            String
  status          SaleStatus      @default(PAID)
  paymentMethod   PaymentMethod
  subtotal        Int
  discount        Int             @default(0)
  tax             Int             @default(0)
  total           Int
  note            String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  storeId         String
  store           Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdBy       User            @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  items           SaleOrderItem[]

  @@unique([storeId, code])
  @@index([storeId, createdAt])
  @@index([storeId, createdAt, id])
  @@index([createdByUserId, createdAt])
}

model SaleOrderItem {
  id              String    @id @default(cuid())
  quantity        Int
  unitPrice       Int
  lineTotal       Int
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  productCode     String
  productName     String
  productCategory String
  orderId         String
  order           SaleOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model InventoryMovement {
  id              String                @id @default(cuid())
  type            InventoryMovementType
  quantityChange  Int
  quantityBefore  Int
  quantityAfter   Int
  reason          String?
  referenceType   String?
  referenceId     String?
  createdAt       DateTime              @default(now())
  storeId         String
  store           Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId       String
  product         Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdByUserId String?
  createdBy       User?                 @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
  @@index([productId, createdAt])
  @@index([referenceType, referenceId])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LoginChallenge {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      AuditAction
  actorUserId String?
  status      String
  ipAddress   String?
  userAgent   String?
  targetType  String?
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action, createdAt])
}
