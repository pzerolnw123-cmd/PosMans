generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlatformRole {
  NONE
  SUPER_ADMIN
}

enum StoreRole {
  OWNER
}

enum OwnerTheme {
  violet
  light
  dark
  mono
  green_white
  orange_pink
}

enum AuditAction {
  CSRF_ISSUED
  LOGIN_SUCCEEDED
  LOGIN_FAILED
  PASSWORD_CHANGED
  LOGOUT
  LOGOUT_ALL
  UPLOAD_POLICY_ISSUED
  PRODUCT_CREATED
  PRODUCT_UPDATED
  PRODUCT_DELETED
  STORE_PROFILE_UPDATED
  STORE_LOGO_UPDATED
  STORE_PAYMENT_SETTINGS_UPDATED
  STORE_LINE_SETTINGS_UPDATED
  STORE_LINE_TEST_SENT
  STORE_LINE_NOTIFICATION_SENT
  STORE_LINE_NOTIFICATION_FAILED
  PLAN_LIMIT_DENIED
  SALE_CREATED
  SALE_CANCELLED
  CUSTOMER_DISPLAY_CREATED
  CUSTOMER_DISPLAY_UPDATED
  CUSTOMER_DISPLAY_REVOKED
  SUPERADMIN_USER_UPDATED
  SUPERADMIN_PLAN_UPDATED
}

enum InventoryMovementType {
  RECEIVE
  SALE
  RETURN
  ADJUSTMENT
  DAMAGE
  CANCEL_SALE
}

enum SaleStatus {
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  QR
  CARD
  TRANSFER
  OTHER
}

enum CustomerDisplayStatus {
  IDLE
  PAYMENT
  SUCCESS
}

enum StorePromptPayRecipientType {
  MOBILE
  NATIONAL_ID
  TAX_ID
  STATIC_QR
  BANK_ACCOUNT
}

enum LineRecipientType {
  USER
  GROUP
  ROOM
}

enum StorePlanTier {
  START
  PLUS
}

enum StorePlanStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

model Store {
  id              String    @id @default(cuid())
  slug            String    @unique
  name            String
  logoUrl         String?
  logoUploadedKey String?
  promptPayEnabled Boolean @default(false)
  promptPayRecipientType StorePromptPayRecipientType @default(MOBILE)
  promptPayId     String?
  promptPayMobileId String?
  promptPayNationalId String?
  promptPayTaxId String?
  bankName        String?
  bankAccountName String?
  bankAccountNumber String?
  paymentQrImageUrl String?
  paymentQrUploadedKey String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  users           User[]
  products        Product[]
  saleOrders      SaleOrder[]
  inventoryMovements InventoryMovement[]
  customerDisplaySessions CustomerDisplaySession[]
  lineIntegration StoreLineIntegration?
  plan            StorePlan?
  planUsages      StorePlanUsage[]
}

model StorePlan {
  id          String          @id @default(cuid())
  storeId     String          @unique
  tier        StorePlanTier   @default(START)
  status      StorePlanStatus @default(ACTIVE)
  expiresAt   DateTime?
  lockVersion Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  store       Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([tier, status])
}

model StorePlanUsage {
  id                  String   @id @default(cuid())
  storeId             String
  period              String
  paymentConfirmCount Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  store               Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, period])
  @@index([storeId, period])
}

model StoreLineIntegration {
  id                          String            @id @default(cuid())
  storeId                     String            @unique
  enabled                     Boolean           @default(false)
  notifyOnSalePaid            Boolean           @default(true)
  recipientType               LineRecipientType @default(USER)
  recipientId                 String?
  channelAccessTokenEncrypted String?
  channelAccessTokenHint      String?
  lastTestedAt                DateTime?
  lastSuccessAt               DateTime?
  lastError                   String?
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt
  store                       Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([enabled, notifyOnSalePaid])
}

model Product {
  id                String   @id @default(cuid())
  code              String
  name              String
  category          String
  price             Int
  costPerUnit       Int      @default(0)
  status            String
  trackStock        Boolean  @default(false)
  stockQuantity     Int      @default(0)
  lowStockThreshold Int      @default(0)
  imageUrl          String?
  uploadedKey       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  storeId           String
  store             Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  saleItems         SaleOrderItem[]
  inventoryMovements InventoryMovement[]

  @@unique([storeId, code])
  @@index([storeId, updatedAt])
  @@index([storeId, category, updatedAt, createdAt])
  @@index([storeId, trackStock, stockQuantity])
}

model User {
  id              String           @id @default(cuid())
  username        String           @unique
  displayName     String
  passwordHash    String
  pinHash         String?
  platformRole    PlatformRole     @default(NONE)
  storeRole       StoreRole?
  ownerTheme      OwnerTheme       @default(light)
  storeId         String?
  isActive        Boolean          @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  store           Store?           @relation(fields: [storeId], references: [id], onDelete: SetNull)
  sessions        Session[]
  auditLogs       AuditLog[]
  loginChallenges LoginChallenge[]
  saleOrders      SaleOrder[]
  inventoryMovements InventoryMovement[]

  @@index([platformRole])
  @@index([storeId, storeRole])
}

model SaleOrder {
  id              String          @id @default(cuid())
  code            String
  status          SaleStatus      @default(PAID)
  paymentMethod   PaymentMethod
  subtotal        Int
  discount        Int             @default(0)
  tax             Int             @default(0)
  total           Int
  note            String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  storeId         String
  store           Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdBy       User            @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  items           SaleOrderItem[]

  @@unique([storeId, code])
  @@index([storeId, createdAt])
  @@index([storeId, createdAt, id])
  @@index([createdByUserId, createdAt])
}

model SaleOrderItem {
  id              String    @id @default(cuid())
  quantity        Int
  unitPrice       Int
  lineTotal       Int
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  productCode     String
  productName     String
  productCategory String
  orderId         String
  order           SaleOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model InventoryMovement {
  id              String                @id @default(cuid())
  type            InventoryMovementType
  quantityChange  Int
  quantityBefore  Int
  quantityAfter   Int
  reason          String?
  referenceType   String?
  referenceId     String?
  createdAt       DateTime              @default(now())
  storeId         String
  store           Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId       String
  product         Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdByUserId String?
  createdBy       User?                 @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
  @@index([productId, createdAt])
  @@index([referenceType, referenceId])
}

model CustomerDisplaySession {
  id              String                @id @default(cuid())
  name            String
  publicTokenHash String                @unique
  ownerControlTokenHash String?         @unique
  status          CustomerDisplayStatus @default(IDLE)
  amount          Int                   @default(0)
  paymentMethod   PaymentMethod?
  qrDataUrl       String?
  message         String?
  saleCode        String?
  lastSeenAt      DateTime?
  expiresAt       DateTime?
  revokedAt       DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  storeId         String
  createdBySessionId String?
  store           Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdBySession Session?             @relation(fields: [createdBySessionId], references: [id], onDelete: SetNull)

  @@index([storeId, updatedAt])
  @@index([revokedAt, expiresAt])
  @@index([createdBySessionId])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerDisplaySessions CustomerDisplaySession[]

  @@index([userId])
  @@index([expiresAt])
}

model LoginChallenge {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      AuditAction
  actorUserId String?
  status      String
  ipAddress   String?
  userAgent   String?
  targetType  String?
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action, createdAt])
}
